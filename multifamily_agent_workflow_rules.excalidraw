    },
    {
      "id": "t-risk-b",
      "type": "text",
      "x": 535,
      "y": 777,
      "width": 930,
      "height": 215,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 45562,
      "version": 1,
      "versionNonce": 765180,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "text": "RED:    DSCR < 1.20x | Occupancy < 85% | Rule #1/#3/#5 triggered\n\nYELLOW: Cap rate below market | Heavy value-add execution risk | Minor rule triggers\n\nGREEN:  Stable occupancy | Rents in line with comps | Conservative leverage | No critical rules triggered\n\nRules:  #1: Occupancy + DSCR\n        #2: Tenant concentration + rollover\n        #3: Deferred maintenance + LTV\n        #4: Market vacancy + rent growth\n        #5: Pro forma vs T-12",
      "originalText": "RED:    DSCR < 1.20x | Occupancy < 85% | Rule #1/#3/#5 triggered\n\nYELLOW: Cap rate below market | Heavy value-add execution risk | Minor rule triggers\n\nGREEN:  Stable occupancy | Rents in line with comps | Conservative leverage | No critical rules triggered\n\nRules:  #1: Occupancy + DSCR\n        #2: Tenant concentration + rollover\n        #3: Deferred maintenance + LTV\n        #4: Market vacancy + rent growth\n        #5: Pro forma vs T-12",
      "lineHeight": 1.4
    },
